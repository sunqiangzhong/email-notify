# ============================================
# Mul-Email 环境变量配置
# ============================================

# 应用端口（宿主机映射端口）
APP_PORT=3000

# 应用版本号（用于更新检测）
APP_VERSION=1.0.0

# JWT 密钥（用于 Token 加密，请修改为随机字符串）
JWT_SECRET=your-random-secret-key-here

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# API 令牌（用于外部访问，可选）
# 设置后可通过以下方式访问：
#   - URL 参数: ?token=your_api_token
#   - Header: X-API-Token: your_api_token
API_TOKEN=

# GitHub Token（可选，用于私有仓库的更新检测）
# 生成地址：https://github.com/settings/tokens
# 需要 repo 权限
GITHUB_TOKEN=

# 时区
TZ=Asia/Shanghai

# ============================================
# 通知渠道配置（可在 Web 界面中配置）
# ============================================
# 企业微信应用
# WECHAT_CORPID=
# WECHAT_APP_SECRET=
# WECHAT_APP_ID=

# Server酱
# SERVER_CHAN_SENDKEY=

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
