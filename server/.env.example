# ========================
# 多邮箱聚合系统 - 环境变量配置
# 复制此文件为 .env 并修改
# ========================

# 服务端口
PORT=3001

# JWT 密钥 (生产环境请更换为强随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-me

# 默认超级管理员 (首次启动自动创建)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@system.local

# 数据存储目录 (建议挂载到 NAS 本地目录)
DATA_DIR=./data

# 邮件轮询间隔 (毫秒), 默认 60000 = 1分钟
MAIL_POLL_INTERVAL=60000

# 前端跨域地址 (逗号分隔多个)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 代理测试超时 (毫秒)
PROXY_TEST_TIMEOUT=10000

# 邮件连接超时 (毫秒)
IMAP_CONNECT_TIMEOUT=30000
