# ========================
# 多邮箱聚合系统 - 环境变量配置
# 复制此文件为 .env 并修改
# ========================

# 服务端口
PORT=3001

# JWT 密钥 (生产环境请更换为强随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-me

# 默认超级管理员 (首次启动自动创建)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@system.local

# 数据存储目录 (建议挂载到 NAS 本地目录)
DATA_DIR=./data

# 前端跨域地址 (逗号分隔多个)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 代理测试超时 (毫秒)
PROXY_TEST_TIMEOUT=10000

# 邮件连接超时 (毫秒)
IMAP_CONNECT_TIMEOUT=30000

# ===== IMAP IDLE 模式配置 =====
# 安全轮询间隔 (毫秒), 默认 300000 = 5分钟
# IDLE 断开时的兜底轮询，一般不需要修改
SAFETY_POLL_INTERVAL=300000

# IDLE 重发间隔 (毫秒), 默认 1740000 = 29分钟
# RFC 建议服务器超时为 29 分钟，保持默认即可
IDLE_REISSUE_INTERVAL=1740000

# 重连基础延迟 (毫秒), 默认 30000 = 30秒
# 断线后首次重连等待时间，会叠加 0~5s 随机抖动
RECONNECT_BASE_DELAY=30000
